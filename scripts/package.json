{
  "name": "@kevindebenedetti/sync-todo",
  "version": "1.0.0",
  "description": "Bidirectional sync between TODO.yml and GitHub Issues",
  "type": "module",
  "private": true,
  "engines": {
    "bun": ">=1"
  },
  "scripts": {
    "push":   "bun run sync-todo.ts push",
    "pull":   "bun run sync-todo.ts pull",
    "labels": "bun run sync-todo.ts labels"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "typescript": "^5.8.2"
  }
}
